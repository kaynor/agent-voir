# GitHub
GITHUB_TOKEN=ghp_...
GITHUB_REPO=kaynor/agent-voir
GITHUB_API_URL=https://api.github.com

# Issue labels
LABEL_TRIGGER=ai-code
LABEL_CLAIMED=ai-code-in-progress
LABEL_DONE=ai-code-pr-created
LABEL_FAILED=ai-code-failed

# Worker
POLL_INTERVAL_SECONDS=60
WORKER_ID=local-bot-1

# Repository checkout (defaults to parent of tools/agentvoir_local_bot)
REPO_PATH=
BASE_BRANCH=main
BRANCH_PREFIX=ai/issue

# Cursor SDK (local agent)
CURSOR_API_KEY=
AGENT_MODEL=composer-2.5

# Commands
TEST_COMMAND=make test
GIT_PUSH_REMOTE=origin

# Git commit identity while the bot is working (restored automatically when done)
GIT_USER_NAME=kailash-coder-bot-01
GIT_USER_EMAIL=

# AgentVoir onebox — copy to deployments/docker/.env.onebox and adjust if needed.
#
# Only these three ports are exposed on your machine. Postgres, Redis, and
# ClickHouse stay inside the agentvoir-onebox Docker network.

# Pre-built app image (published to GHCR on GitHub Release — one package per repo)
AGENTVOIR_IMAGE=ghcr.io/kaynor/agent-voir
AGENTVOIR_VERSION=latest

# Host ports (change if you already use 8080/8081/8082)
AGENTVOIR_GATEWAY_PORT=8080
AGENTVOIR_REGISTRY_PORT=8081
AGENTVOIR_USAGE_PORT=8082

# Gateway auth key for OpenAI-compatible clients
GATEWAY_API_KEY=agentvoir-onebox-key

# Browser console CORS (Live Proxy Flow UI at http://localhost:3000)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Optional: real provider key for live model calls (mock provider works without this)
OPENAI_API_KEY=

# --- OIDC (optional) ---
# Enable Dex + JWT auth: add -f deployments/docker/docker-compose.onebox.oidc.yml
# OIDC_ISSUER_URL=http://dex:5556/dex
# OIDC_CLIENT_ID=agentvoir
# OIDC_CLIENT_SECRET=agentvoir-dev-secret
# OIDC_GROUPS_CLAIM=groups
# REGISTRY_API_KEY=   # optional bootstrap key alongside JWT
REGISTRY_API_KEY=agentvoir-internal-registry-key
DEX_PORT=5556
